# AI Agent School Environment Variables

# MiniMax LLM Configuration
MINIMAX_API_KEY=your_minimax_api_key_here

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_school

# Application Settings
DEBUG=false
HOST=0.0.0.0
PORT=8080
WORKERS=4

# Communication
POLL_INTERVAL=5
MESSAGE_TIMEOUT=300

# Graduation
GRADUATION_STREAK_DAYS=7

# Cron Monitoring
HEARTBEAT_INTERVAL=300
GRACE_PERIODS=2
MAX_RETRIES=3
